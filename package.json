{
    "name": "arrow-cloud-prototype",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "watch": "esbuild src/main.labs.js --bundle --outfile=dist/main.labs.js --sourcemap --watch",
        "serve": "browser-sync start --server . --files 'index.html, src/**/*.js, dist/**/*.js'",
        "dev": "npm-run-all --parallel watch serve",
        "build:prod": "esbuild src/main.js --bundle --outfile=dist/main.js --minify --metafile=dist/main.meta.json --analyze=verbose",
        "build:labs": "esbuild src/main.labs.js --bundle --outfile=dist/main.labs.js --sourcemap",
        "build:runtime": "esbuild src/createArrowCloudRuntime.js --bundle --format=esm --outfile=dist/arrow-cloud-runtime.js --minify",
        "build:labs-runtime": "esbuild src/createArrowCloudLabsRuntime.js --bundle --format=esm --outfile=dist/arrow-cloud-labs-runtime.js --sourcemap",
        "build": "npm-run-all build:prod build:labs"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "esbuild": "^0.28.1",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "browser-sync": "^3.0.4",
        "npm-run-all": "^4.1.5"
    }
}